# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/deck-lotus.db

# ── JWT (REQUIRED — use a long random string in production) ────────────────────
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Admin user (created on first startup if no admin exists) ───────────────────
# If not set, credentials are auto-generated and printed to the console once.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ── Mana Pool API ──────────────────────────────────────────────────────────────
# Primary price source, cart optimizer, deck validator, and buy links.
# Generate your token at: https://manapool.com/seller/settings/integrations
# Both the email address of your Mana Pool account and the API token are required.
MANAPOOL_USER_EMAIL=
MANAPOOL_API_TOKEN=

# ── TCGPlayer API (fallback — API keys no longer publicly issued) ──────────────
TCGPLAYER_CLIENT_ID=
TCGPLAYER_CLIENT_SECRET=

# ── ntfy push notifications ────────────────────────────────────────────────────
# Receive a push notification when a price watch hits your target price.
# Use the public server (https://ntfy.sh) or self-host. Pick a unique topic name.
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=your-unique-topic-name

# ── Price monitoring schedule ──────────────────────────────────────────────────
# Cron expression — default checks every 6 hours.
PRICE_CHECK_SCHEDULE=0 */6 * * *

# ── Card data ──────────────────────────────────────────────────────────────────
# Override the MTGJSON download URL (rarely needed).
MTGJSON_URL=https://mtgjson.com/api/v5/AllPrintings.sqlite.bz2

# Set to 'true' to force a full reimport of MTGJSON card data on next startup.
# User decks are preserved via stable UUIDs during the reimport.
FORCE_REIMPORT=false
